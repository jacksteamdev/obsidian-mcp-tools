# Fake values for unit tests that transitively import modules using the
# build-time `environmentVariables()` macro from
# src/features/mcp-server-install/constants/bundle-time.ts.
#
# The macro reads these at module load; without them set, any test that
# imports install.ts (directly or transitively) fails at load time with
# an ArkType validation error.
#
# Bun automatically loads `.env.test` when `bun test` runs. Keeping the
# values obviously-fake makes it clear to anyone reading the test suite
# that no real GitHub release URL is being hit from unit tests.
GITHUB_DOWNLOAD_URL=https://example.test/release
GITHUB_REF_NAME=v0.0.0
